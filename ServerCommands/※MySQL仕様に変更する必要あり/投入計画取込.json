          "Item2": 22
        }
      },
      "SqlStatement": "insert into ymia_t_seisan_schedule\r\nselect distinct 艇種, 艇番 from 生産統括部.dbo.投入計画管理 where 積層投入 >= @投入計画設定日  and \r\n(艇種 is not null and 艇番 is not null)\r\norder by 艇種, 艇番",
      "ReturnsName": "エラー値",
