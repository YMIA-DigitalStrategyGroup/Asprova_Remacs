    "SourceTableSchema": "",
    "CreateViewSql": "select `t1`.`工事区分` AS `工事区分`,`t1`.`工事番号` AS `工事番号`,`t1`.`艇種` AS `艇種`,`t1`.`社員コード` AS `社員コード`,`t1`.`工程コード` AS `工程コード`,`t1`.`日付` AS `日付`,`t1`.`作業内容` AS `作業内容`,`t1`.`作業時間` AS `作業時間`,(select `m`.`KOTEI_NAME` from `mkoteiname` `m` where (`m`.`KOTEI_CODE` = `t1`.`工程コード`) limit 1) AS `KOTEI_NAME` from `ymia_t_seisan_jissekikouji` `t1` where (`t1`.`工事区分` <> '-')",
