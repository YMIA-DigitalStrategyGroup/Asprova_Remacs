    "CreateViewSql": "(\r\n    SELECT \r\n        艇種, \r\n        艇番, \r\n        積層投入 \r\n    FROM \r\n        投入計画管理_海洋 \r\n    WHERE \r\n        (艇種 IS NOT NULL AND 艇番 IS NOT NULL) \r\n        AND 設定日付 = (SELECT 設定日付 FROM V投入計画_最新日付_海洋) -- ここを書き換えました\r\n)\r\n\r\n/*\r\nメモ書き（旧ロジックまたは参考クエリ）:\r\nSELECT DISTINCT 艇種, 艇番 FROM 投入計画管理_海洋 \r\nWHERE 積層投入 > '2025/8/20' AND \r\n(艇種 IS NOT NULL AND 艇番 IS NOT NULL)\r\nORDER BY 艇種, 艇番\r\n*/",
