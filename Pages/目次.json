  "PageInfo": {
    "$type": "Forguncy.Model.Pages.NormalPage, ServerDesignerCommon",
    "MasterPageName": "生産実績入力メニュー",
    "PageLoadedCommandList": [
      {
        "$type": "Forguncy.Model.RunJavaScriptCommand, ServerDesignerCommon",
        "JavaScript": "(function () {\r\n    // ----------------------------\r\n    // ツールチップ要素\r\n    // ----------------------------\r\n    const tooltip = document.createElement(\"div\");\r\n    Object.assign(tooltip.style, {\r\n        position: \"fixed\",\r\n        padding: \"6px 10px\",\r\n        background: \"rgba(0,0,0,0.8)\",\r\n        color: \"#fff\",\r\n        borderRadius: \"6px\",\r\n        fontSize: \"13px\",\r\n        pointerEvents: \"none\",\r\n        whiteSpace: \"nowrap\",\r\n        opacity: \"0\",\r\n        transition: \"opacity 0.15s\",\r\n        zIndex: 9999,\r\n    });\r\n    document.body.appendChild(tooltip);\r\n\r\n    // ----------------------------\r\n    // ツールチップテキスト（キーは「前方一致部分」）\r\n    // ----------------------------\r\n    const tooltipTexts = {\r\n        r4c7p: \"日常作業実績入力はこちら\",\r\n        r13c7p: \"その他作業実績入力はこちら（船やモノの移動、確認相談、諸活動,OJT等...）\",\r\n        r22c7p: \"特殊工事実績入力はこちら（G番、I番、P番、T番、W番のように工事番号があるもの）\"\r\n    };\r\n\r\n    // ----------------------------\r\n    // イベント付与関数\r\n    // ----------------------------\r\n    function attachEvents(btn, key) {\r\n        if (!btn) return;\r\n\r\n        // 既存 handler を削除\r\n        if (btn._mouseenterHandler) {\r\n            btn.removeEventListener(\"mouseenter\", btn._mouseenterHandler);\r\n            btn.removeEventListener(\"mouseleave\", btn._mouseleaveHandler);\r\n        }\r\n\r\n        btn._mouseenterHandler = () => {\r\n            tooltip.textContent = tooltipTexts[key];\r\n            tooltip.style.opacity = \"1\";\r\n\r\n            const rect = btn.getBoundingClientRect();\r\n            tooltip.style.left = rect.left + rect.width / 2 + \"px\";\r\n            tooltip.style.top = rect.top - 30 + \"px\";\r\n            tooltip.style.transform = \"translateX(-50%)\";\r\n        };\r\n\r\n        btn._mouseleaveHandler = () => {\r\n            tooltip.style.opacity = \"0\";\r\n        };\r\n\r\n        btn.addEventListener(\"mouseenter\", btn._mouseenterHandler);\r\n        btn.addEventListener(\"mouseleave\", btn._mouseleaveHandler);\r\n\r\n        console.log(\"✔ イベント再付与:\", btn.id);\r\n    }\r\n\r\n    // ----------------------------\r\n    // Forguncy が完全描画した後に呼びたい処理\r\n    // ----------------------------\r\n    let timer = null;\r\n    function delayedCheck() {\r\n        clearTimeout(timer);\r\n        timer = setTimeout(() => {\r\n            Object.keys(tooltipTexts).forEach(key => {\r\n                const selector = `[id^='${key}'][id$='_btn']`;\r\n                const btn = document.querySelector(selector);\r\n                if (btn) attachEvents(btn, key);\r\n            });\r\n        }, 50); // 初期値のまま\r\n    }\r\n\r\n    // ----------------------------\r\n    // MutationObserver\r\n    // Forguncy の内部更新すべてを拾う\r\n    // ----------------------------\r\n    const observer = new MutationObserver(delayedCheck);\r\n    observer.observe(document.body, {\r\n        childList: true,\r\n        subtree: true,\r\n        attributes: true,\r\n        characterData: true,\r\n    });\r\n\r\n    // ----------------------------\r\n    // Forguncy ページ遷移時にも再チェック\r\n    // ----------------------------\r\n    window.FgcPageLoaded = function () {\r\n        console.log(\"✔ FgcPageLoaded: Forguncyページロード検出\");\r\n        delayedCheck();\r\n    };\r\n\r\n})();",
        "ID": "09830ed71f04493f9415f3893deb1775"
      }
